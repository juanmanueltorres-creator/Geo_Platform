# ============================================================
# GeoPlatform API — Environment Configuration
# Copy this file to api/.env and fill in real values.
# NEVER commit api/.env to version control.
# ============================================================

# Required — Supabase connection string
# Get from: Supabase dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@<project-ref>.supabase.co:5432/postgres

# Optional — Connection pool tuning (defaults shown)
# Increase DB_CONNECT_TIMEOUT and DB_CONN_RETRIES if using Supabase Free Tier
# (project may take 30-60s to wake from pause)
DB_CONN_RETRIES=5
DB_CONN_RETRY_BACKOFF=3
DB_CONNECT_TIMEOUT=15
DB_POOL_MIN=1
DB_POOL_MAX=10

# Required for /debug-db endpoint
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=<generate-a-secure-random-token>
